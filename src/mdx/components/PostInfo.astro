---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<div class="my-4 flex w-full rounded-lg bg-amber-50 p-4 text-slate-800">
  <div class="items-top mr-4 flex shrink-0 justify-center pt-2 text-4xl">ℹ️</div>
  <div>
    {title && <h2 class="mb-1 text-2xl font-bold">{title}</h2>}
    <slot />
  </div>
</div>
