---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

type ImageSource = string | ImageMetadata;

interface Props {
  src: ImageSource;
  alt?: string;
  placeholder?: string;
  width?: number | string;
  height?: number | string;
  sizes?: string;
  class?: string;
}

const {
  src,
  alt = '',
  placeholder: _placeholder,
  width,
  height,
  sizes = '(max-width: 50rem) calc(100vw - 2rem), 48rem',
  class: className = '',
  ...props
} = Astro.props;
---

{
  typeof src === 'string' ? (
    <img {...props} src={src} alt={alt} width={width} height={height} class={`h-auto max-w-full ${className}`.trim()} />
  ) : (
    <Image
      {...props}
      src={src}
      alt={alt}
      width={width}
      height={height}
      widths={[480, 768, 960]}
      sizes={sizes}
      class={`h-auto max-w-full ${className}`.trim()}
    />
  )
}
