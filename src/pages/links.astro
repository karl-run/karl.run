---
import RootLayout from '@layouts/RootLayout.astro';

const links = [
  {
    name: 'Github',
    link: 'https://github.com/karl-run',
    imageHash:
      'data:image/svg+xml;base64,',
  },
  {
    name: 'LinkedIn',
    link: 'https://www.linkedin.com/in/karloveraa/',
    imageHash:
      'data:image/svg+xml;base64,',
  },
  {
    name: 'Bluesky',
    link: 'https://bsky.app/profile/karl.run',
    imageHash:
      'data:image/svg+xml;base64,',
  },
  {
    name: 'E-mail',
    link: 'mailto:k@rl.run',
    imageHash:
      'data:image/svg+xml;base64,',
  },
];
---

<RootLayout>
  <main class="mx-auto mt-16 flex max-w-md flex-col gap-4 p-4">
    {links.map(({ name, link, imageHash }) => (
      <a
        rel="noopener noreferrer"
        target="_blank"
        href={link}
        title={name}
        class="relative flex w-full items-center justify-center rounded border p-4 backdrop-blur-sm transition-transform hover:scale-105 focus:scale-105"
      >
        <img src={imageHash} alt="" width="32" height="32" class="absolute left-4" />
        {name}
      </a>
    ))}
  </main>
</RootLayout>
